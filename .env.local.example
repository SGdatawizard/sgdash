# Copy this file to .env.local and fill in your Supabase project's values.
# Find both under Supabase → Project Settings → API.

# Project URL, e.g. https://abcdefghijk.supabase.co
SUPABASE_URL=https://jjogvmnwvgdsekftmfgd.supabase.co

# Project API keys → service_role (secret) key — NOT the anon/public key.
# This lets the server read/write without Row Level Security getting in
# the way. It must never be prefixed with NEXT_PUBLIC_ and never be sent
# to the browser — this app only ever uses it from server-side code.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Impqb2d2bW53dmdkc2VrZnRtZmdkIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3ODY4MTIwNSwiZXhwIjoyMDk0MjU3MjA1fQ.s0aDV25SIbDOjQPtEVpvk0b1d0HkU8pT6AwmaQUzaSk
